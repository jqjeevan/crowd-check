      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-main"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "WITH latest_nodes AS (\n  SELECT\n    node_id,\n    argMax(label, updated_at) AS label,\n    argMax(latitude, updated_at) AS latitude,\n    argMax(longitude, updated_at) AS longitude\n  FROM crowd_check.camera_nodes\n  GROUP BY node_id\n),\nselected_nodes AS (\n  SELECT\n    node_id,\n    label,\n    latitude,\n    longitude\n  FROM latest_nodes\n  WHERE label IN (${Bus_Stop_Name:sqlstring})\n),\nlatest_detection_ts AS (\n  SELECT\n    d.node_id,\n    max(d.timestamp) AS latest_timestamp\n  FROM crowd_check.detections AS d\n  INNER JOIN selected_nodes ON selected_nodes.node_id = d.node_id\n  WHERE $__timeFilter(d.timestamp)\n  GROUP BY d.node_id\n),\nlatest_tier_counts AS (\n  SELECT\n    d.node_id,\n    countIf(d.congestion_tier = 1) AS tier_1_count,\n    countIf(d.congestion_tier = 2) AS tier_2_count,\n    countIf(d.congestion_tier = 3) AS tier_3_count\n  FROM crowd_check.detections AS d\n  INNER JOIN latest_detection_ts\n    ON latest_detection_ts.node_id = d.node_id\n   AND latest_detection_ts.latest_timestamp = d.timestamp\n  GROUP BY d.node_id\n),\nlatest_counts AS (\n  SELECT\n    node_id,\n    (tier_1_count + tier_2_count + tier_3_count) AS total_detection_count\n  FROM latest_tier_counts\n)\nSELECT\n  selected_nodes.label AS name,\n  selected_nodes.latitude AS latitude,\n  selected_nodes.longitude AS longitude,\n  latest_counts.total_detection_count AS value,\n  latest_counts.total_detection_count AS total_detection_count\nFROM latest_counts\nINNER JOIN selected_nodes ON selected_nodes.node_id = latest_counts.node_id\nARRAY JOIN range(greatest(1, least(20, latest_counts.total_detection_count))) AS heat_repeat\nWHERE latest_counts.total_detection_count > 0\nORDER BY total_detection_count DESC, name",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-main"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "WITH latest_nodes AS (\n  SELECT\n    node_id,\n    argMax(label, updated_at) AS label,\n    argMax(latitude, updated_at) AS latitude,\n    argMax(longitude, updated_at) AS longitude\n  FROM crowd_check.camera_nodes\n  GROUP BY node_id\n),\nselected_nodes AS (\n  SELECT\n    node_id,\n    label,\n    latitude,\n    longitude\n  FROM latest_nodes\n  WHERE label IN (${Bus_Stop_Name:sqlstring})\n),\nlatest_detection_ts AS (\n  SELECT\n    d.node_id,\n    max(d.timestamp) AS latest_timestamp\n  FROM crowd_check.detections AS d\n  INNER JOIN selected_nodes ON selected_nodes.node_id = d.node_id\n  WHERE $__timeFilter(d.timestamp)\n  GROUP BY d.node_id\n),\nlatest_tier_counts AS (\n  SELECT\n    d.node_id,\n    countIf(d.congestion_tier = 1) AS tier_1_count,\n    countIf(d.congestion_tier = 2) AS tier_2_count,\n    countIf(d.congestion_tier = 3) AS tier_3_count\n  FROM crowd_check.detections AS d\n  INNER JOIN latest_detection_ts\n    ON latest_detection_ts.node_id = d.node_id\n   AND latest_detection_ts.latest_timestamp = d.timestamp\n  GROUP BY d.node_id\n),\nlatest_counts AS (\n  SELECT\n    node_id,\n    tier_1_count,\n    tier_2_count,\n    tier_3_count,\n    greatest(tier_1_count, tier_2_count, tier_3_count) AS dominant_count,\n    multiIf(\n      tier_3_count >= tier_2_count AND tier_3_count >= tier_1_count, 3,\n      tier_2_count >= tier_1_count, 2,\n      1\n    ) AS dominant_tier,\n    (tier_1_count + tier_2_count + tier_3_count) AS total_detection_count\n  FROM latest_tier_counts\n)\nSELECT\n  selected_nodes.label AS name,\n  selected_nodes.latitude AS latitude,\n  selected_nodes.longitude AS longitude,\n  coalesce(latest_counts.total_detection_count, 0) AS value,\n  coalesce(latest_counts.total_detection_count, 0) AS total_detection_count,\n  coalesce(latest_counts.dominant_tier, 0) AS dominant_tier,\n  coalesce(latest_counts.dominant_count, 0) AS dominant_count,\n  coalesce(latest_counts.tier_1_count, 0) AS tier_1_count,\n  coalesce(latest_counts.tier_2_count, 0) AS tier_2_count,\n  coalesce(latest_counts.tier_3_count, 0) AS tier_3_count\nFROM selected_nodes\nLEFT JOIN latest_counts ON selected_nodes.node_id = latest_counts.node_id\nORDER BY total_detection_count DESC, name",
          "refId": "B"
        }
      ],
